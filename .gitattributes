###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto

###############################################################################
# RocketSim3D - C++ Source Files (Windows MSVC project → CRLF)
###############################################################################
*.cpp       text eol=crlf
*.h         text eol=crlf
*.hpp       text eol=crlf
*.c         text eol=crlf
*.inl       text eol=crlf
*.tpp       text eol=crlf

###############################################################################
# Build Scripts (Windows → CRLF)
###############################################################################
*.bat       text eol=crlf
*.cmd       text eol=crlf

###############################################################################
# GPU Shaders (cross-platform → LF)
###############################################################################
*.frag      text eol=lf
*.vert      text eol=lf
*.glsl      text eol=lf
*.comp      text eol=lf
*.spv       binary

###############################################################################
# Data & Config Files (cross-platform → LF)
###############################################################################
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf

###############################################################################
# Binary Assets
###############################################################################
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.tga       binary
*.dds       binary
*.ktx       binary
*.otf       binary
*.ttf       binary
*.wav       binary
*.ogg       binary
*.mp3       binary

# 3D Model & Material files
*.fbx       binary
*.gltf      text eol=lf
*.glb       binary
*.mtl       text eol=lf
# Note: *.obj is ambiguous (compiler object vs 3D model).
# Compiler .obj files should be in .gitignore.
# 3D model .obj files in assets/ can be tracked as binary:
# assets/**/*.obj binary

###############################################################################
# Build System Files (Visual Studio)
###############################################################################
*.sln       text eol=crlf
*.slnx      text eol=crlf
*.vcxproj   text eol=crlf
*.vcxproj.filters text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf

###############################################################################
# Binary Build Artifacts (should also be in .gitignore)
###############################################################################
*.exe       binary
*.dll       binary
*.lib       binary
*.pdb       binary
*.ilk       binary
*.obj       binary
*.o         binary
*.a         binary
*.so        binary
